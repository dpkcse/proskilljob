{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2.0",
        "ext-curl": "*",
        "ext-pdo": "*",
        "anhskohbo/no-captcha": "^3.4",
        "astrotomic/laravel-translatable": "^11.11",
        "barryvdh/laravel-dompdf": "^3.0",
        "daftspunk/laravel-config-writer": "^1.2.2",
        "dgvai/laravel-sslcommerz": "^1.0",
        "f9webltd/laravel-api-response-helpers": "^2",
        "fruitcake/php-cors": "^1.3",
        "google/apiclient": "^2.18",
        "guzzlehttp/guzzle": "^7.9",
        "imliam/laravel-env-set-command": "^2.0",
        "instamojo/instamojo-php": "^1.0",
        "intervention/image": "^2.7",
        "iyzico/iyzipay-php": "^2.0",
        "jackiedo/dotenv-editor": "^1.1",
        "jorenvanhocht/laravel-share": "^4.2",
        "kreait/laravel-firebase": "^6",
        "ladumor/laravel-pwa": "^0.0.5",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.1",
        "laravel/socialite": "^5.21",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.6.0",
        "laravolt/avatar": "^5.0",
        "litespeed/lscache-laravel": "^1.3",
        "livewire/livewire": "^3.4",
        "maatwebsite/excel": "^3.1",
        "maennchen/zipstream-php": "^3.1",
        "midtrans/midtrans-php": "^2.6",
        "mollie/laravel-mollie": "^3.1",
        "nwidart/laravel-modules": "^11",
        "opcodesio/log-viewer": "*",
        "propaganistas/laravel-disposable-email": "^2.4",
        "psr/http-factory": "^1.1",
        "pusher/pusher-php-server": "^7.2",
        "razorpay/razorpay": "^2.8",
        "sentry/sentry-laravel": "^4.14",
        "spatie/browsershot": "^5.0",
        "spatie/laravel-medialibrary": "^11",
        "spatie/laravel-permission": "^6.20",
        "spatie/laravel-sitemap": "^7.3",
        "srmklive/paypal": "^3.0",
        "stevebauman/location": "^7.5",
        "stichoza/google-translate-php": "^5.3",
        "stripe/stripe-php": "^7.119",
        "torann/geoip": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.15",
        "fakerphp/faker": "^1.9.1",
        "getsolaris/laravel-make-service": "^1.1",
        "laravel/pint": "^1.12",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^2.0",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
